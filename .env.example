# DebMirror Manager
# Host-Ports. Diese Werte darfst du ändern.
WEBUI_PORT=8111
MIRROR_HTTP_PORT=8110

# Admin-Zugang.
# Empfehlung: über ./install.sh, ./set-admin-password.sh oder die /setup-Seite setzen.
# settings.json im Datenverzeichnis hat Vorrang vor diesen .env-Werten.
APP_USERNAME=
APP_PASSWORD=
APP_PASSWORD_HASH=

# Wichtig: eigener Secret Key für Flask-Sessions.
APP_SECRET_KEY=please-change-this-secret

# Host-Pfad für persistente Verwaltungsdaten, Logs, Keyrings, Backups und Import-Skripte.
DATA_PATH=/docker_data/debmirror-manager

# Host-Pfad, in dem die lokalen Repository-Spiegel liegen.
# Dieser Pfad wird im App-Container als /mirror gemountet. Optional kann der nginx-Container ihn als Webroot ausliefern.
MIRROR_PATH=/srv/mirror

# Optionaler nginx-Container zur HTTP-Auslieferung der Mirror-Daten.
# 1 = nginx mit Compose-Profil mirror-http starten, 0 = nur WebUI starten und eigenen Webserver nutzen.
USE_NGINX_MIRROR_HTTP=1

# Host-Pfade, die beim Import alter Skripte automatisch auf /mirror gemappt werden.
# Beispiel: /mnt/linux-mirror/scpcom -> /mirror/scpcom
IMPORT_HOST_MIRROR_PATHS=/srv/mirror

# Interne Containerpfade.
APP_DATA_DIR=/app/data
APP_LOG_DIR=/app/logs
APP_KEYRING_DIR=/app/keyrings
APP_BACKUP_DIR=/app/backups
IMPORT_SCRIPT_DIR=/import-scripts
USER_SCRIPT_DIR=/user-scripts
MIRROR_BASE=/mirror

# Scheduler scan interval in seconds.
SCHEDULER_SCAN_SECONDS=60

# Globale Job-Warteschlange und Log-/Job-Aufbewahrung.
MAX_PARALLEL_JOBS=1
JOB_RETENTION_DAYS=31
JOB_LIST_LIMIT=100
DASHBOARD_RECENT_JOBS_LIMIT=10
DASHBOARD_EVENTS_LIMIT=10

# Maximum seconds to wait after stop before force killing a debmirror process group.
JOB_STOP_GRACE_SECONDS=20

# Lokales Projekt-Unterverzeichnis für Update-ZIPs. Wird von update.sh/install.sh verwendet.
UPDATE_DIR=updates

# Verzeichnis für Backups, die update.sh vor Datei-/Containerupdates erstellt.
# Relativer Standard: backup im Projektordner. WebUI-Vollbackups bleiben im App-Backup-Volume.
UPDATE_BACKUP_DIR=backup

# Benachrichtigungen werden in settings.json über die WebUI gespeichert.
# Unterstützt: SMTP-Mail, Telegram, Discord.
# API-Tokens werden ebenfalls in der WebUI erzeugt und nur gehasht gespeichert.

# Mirror-Größenberechnung für große Repositorys.
# Die WebUI nutzt einen Cache und berechnet Größen im Hintergrund, damit große Mirrors keine Seitenaufrufe blockieren.
SIZE_CACHE_TTL_SECONDS=21600
SIZE_CALC_TIMEOUT_SECONDS=1800
SIZE_CALC_MAX_PARALLEL=2

# Automatische Größenberechnung nach Job-Ruhefenster.
# 1 = aktiv, 0 = deaktiviert. AUTO_SIZE_IDLE_MINUTES=120 bedeutet: nur starten, wenn in den nächsten 2 Stunden kein geplanter Job fällig ist.
AUTO_SIZE_RECALC_ENABLED=1
AUTO_SIZE_IDLE_MINUTES=120


# Lokale Zeitzone für WebUI-Zeitstempel und Logs.
APP_TIMEZONE=Europe/Berlin
TZ=Europe/Berlin

# Speicherplatz-Sperre für echte Mirror-Jobs.
# Wenn MIRROR_BASE/MIRROR_PATH den Grenzwert erreicht, bleiben echte Mirror-Jobs in der Warteschlange bzw. werden nicht neu eingereiht.
STORAGE_GUARD_ENABLED=1
STORAGE_GUARD_THRESHOLD_PERCENT=95
